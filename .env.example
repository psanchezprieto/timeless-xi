# ─── Frontend (Vite) ────────────────────────────────────────────────────────
# These are baked into the JS bundle at build time by Vite.
# VITE_* vars are SAFE to expose in the browser — they are write-only tokens.

# PostHog project write key (get from PostHog → Project Settings → Project API key)
VITE_POSTHOG_KEY=phc_REPLACE_WITH_YOUR_KEY

# PostHog data region. Use https://eu.posthog.com if your project is in the EU region.
VITE_POSTHOG_HOST=https://us.posthog.com

# Set to 'false' to disable all analytics locally (useful during dev)
VITE_POSTHOG_ENABLED=true

# ─── Server-side scripts only (GitHub Actions / local enrichment) ────────────
# These NEVER go in the frontend. Add them as GitHub Secrets for CI.

# Anthropic API key — used by scripts/enrich-ratings.mjs
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# PostHog personal API key — used by future stats page GitHub Actions job
# (get from PostHog → User icon → Personal API keys → Create)
POSTHOG_PERSONAL_KEY=phx_REPLACE_WITH_YOUR_KEY

# Zafronix API key — used by scripts/fetch-squads.mjs
ZAFRONIX_API_KEY=REPLACE_IF_NEEDED
