{
  "name": "timeless-xi",
  "version": "0.1.0",
  "description": "World Cup simulation game - build dream teams and win tournaments",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "fetch": "node scripts/fetch-squads.mjs",
