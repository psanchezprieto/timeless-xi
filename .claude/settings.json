{
  "env": {
    "PATH": "/home/botuser/.nvm/versions/node/v24.16.0/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"✅ Commit successful! Check docs/HANDOFF.md for next steps and the resume prompt.\"}'",
            "statusMessage": "Session handoff reminder..."
          }
        ]
      }
    ]
  }
}
